{
  "name": "subscription-bot",
  "version": "0.1.0",
  "description": "Privacy-oriented Telegram subscription management bot on Cloudflare Workers",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "command:push": "node scripts/pushCommands.mjs",
    "types:check": "tsc --noEmit",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint src/ test/ --fix",
    "format": "biome format --write src/ test/",
    "format:check": "biome format src/ test/",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@cf-wasm/resvg": "^0.3.4",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@grammyjs/conversations": "^2.1.1",
    "dayjs": "^1.11.21",
    "grammy": "^1.44.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@types/node": "^22.19.19",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/coverage-v8": "2.1.9",
    "eslint": "^8.57.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9",
    "wrangler": "^4.107.0"
  },
  "packageManager": "pnpm@9.12.1",
  "engines": {
    "node": ">=22.0.0"
  }
}
