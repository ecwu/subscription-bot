{
  "name": "subscription-bot",
  "version": "0.1.0",
  "description": "Privacy-oriented Telegram subscription management bot on Cloudflare Workers",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "command:push": "node scripts/pushCommands.mjs",
    "types:check": "tsc --noEmit",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint src/ test/ --fix",
    "format": "biome format --write src/ test/",
    "format:check": "biome format src/ test/",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@cf-wasm/resvg": "^0.3.4",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@grammyjs/conversations": "^2.1.1",
    "grammy": "^1.30.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/workers-types": "^4.20241022.0",
    "@types/node": "^22.7.5",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^8.57.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2",
    "wrangler": "^4.92.0"
  },
  "packageManager": "pnpm@9.12.1",
  "engines": {
    "node": ">=20.0.0"
  }
}
