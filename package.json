{
  "name": "subscription-bot",
  "version": "0.1.0",
  "description": "Privacy-oriented Telegram subscription management bot on Cloudflare Workers",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "command:push": "node scripts/pushCommands.mjs",
    "types:check": "tsc --noEmit",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint src/ test/ --fix",
    "format": "biome format --write src/ test/",
    "format:check": "biome format src/ test/",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@cf-wasm/resvg": "^0.3.4",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@grammyjs/conversations": "^2.1.1",
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2",
    "dayjs": "^1.11.21",
    "grammy": "^1.44.0",
    "satori": "^0.26.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@cloudflare/workers-types": "^5.20260706.1",
    "@eslint/js": "^10",
    "@types/d3-array": "^3.2.2",
    "@types/d3-scale": "^4.0.9",
    "@types/node": "^26.1.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "typescript": "^6.0.3",
    "vite": "^8",
    "vitest": "^4.1.10",
    "wrangler": "^4.107.0"
  },
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22.0.0"
  }
}
