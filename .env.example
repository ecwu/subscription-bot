# Telegram Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# Webhook secret for validating Telegram requests
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here

# Master encryption key used for application-level encryption.
# Must be a base64url-encoded 32-byte (256-bit) value.
# Generate one with:
#   node -e "console.log(Buffer.from(crypto.randomBytes(32)).toString('base64url'))"
ENCRYPTION_KEY=your_base64url_32byte_key_here

# Secret used to hash Telegram user IDs into opaque KV keys.
# Should be a high-entropy random string (e.g., 32+ chars).
USER_HASH_SECRET=your_user_hash_secret_here

# Optional: restrict bot to a single admin Telegram user ID.
# When unset, all users are allowed (development mode).
ADMIN_USER_ID=12345678

# Application environment. Affects dev-only commands like /debug_me.
# Valid values: development, production, test
APP_ENV=development

# Number of days ahead to send renewal reminders (default: 3)
REMINDER_DAYS_AHEAD=3

# Optional: XCurrency commercial data API key used by /admin_sync_exchange_rates.
XCURRENCY_API_KEY=your_xcurrency_api_key_here
